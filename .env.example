# Sample .env — copy to `.env` and fill in your own values.
# Never commit `.env` to git. The `.gitignore` already excludes it.

# Google AI Studio (Gemini). Get one at https://aistudio.google.com → API keys.
GOOGLE_API_KEY=

# Local model endpoints. Pick ONE (or both — they use different ports):
#   - Ollama (CLI) — https://ollama.com
#   - LM Studio (GUI) — https://lmstudio.ai, default port is 1234
OLLAMA_HOST=http://127.0.0.1:11434
LMSTUDIO_HOST=http://127.0.0.1:1234
